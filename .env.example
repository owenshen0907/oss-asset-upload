# Alibaba Cloud OSS credentials. Do not commit real values.
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_SECURITY_TOKEN=

# Example: oss-cn-shanghai.aliyuncs.com
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
OSS_REGION=cn-shanghai

# Recommended bucket for AiTool content assets:
# OSS_BUCKET=owenshen-aitool-assets
OSS_BUCKET=

# Prefer a CDN/custom domain when available. If omitted, the CLI builds
# https://<bucket>.<endpoint>/<object-key>.
OSS_PUBLIC_BASE_URL=

# Default object prefix used when --prefix is omitted.
OSS_ASSET_PREFIX=notes

# Safe default for hashed filenames.
OSS_CACHE_CONTROL=public, max-age=31536000, immutable
